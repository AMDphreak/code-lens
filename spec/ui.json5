// Transferable UI behavior — load into any implementation.
{
  version: 1,
  interaction: {
    desktop: {
      preview: "hover",
      commit: "click",
      keyboard: true,
    },
    touch: {
      preview: "swipe",
      commit: "tap",
      swipeThresholdPx: 48,
      swipeRevealOpacity: 0.35,
    },
  },
  animation: {
    widthMs: 420,
    widthEasing: "cubic-bezier(0.16, 1, 0.3, 1)",
    fadeMs: 220,
    fadeDelayMs: 60,
    glassSlideMs: 320,
    panelCrossfadeMs: 200,
    diffTokenPaddingPx: 4,
    diffTokenRadiusPx: 3,
    // Literal glass lens sweep over each diff token during morph
    glassLensPassMs: 520,
    glassLensLineStaggerMs: 55,
  },
  layout: {
    tabMinHeightPx: 28,
    codeFontFamily: '"Space Mono", "SF Mono", "Fira Code", monospace',
    codeFontSizePx: 13,
    glassBlurPx: 12,
  },
}
