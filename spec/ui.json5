// Transferable UI behavior — load into any implementation.
{
  version: 1,
  interaction: {
    desktop: {
      preview: "hover",
      commit: "click",
      keyboard: true,
    },
    touch: {
      preview: "tabs",
      commit: "tap",
      swipeThresholdPx: 48,
      swipeRevealOpacity: 0.35,
    },
  },
  animation: {
    widthMs: 420,
    widthEasing: "cubic-bezier(0.16, 1, 0.3, 1)",
    fadeMs: 220,
    fadeDelayMs: 60,
    glassSlideMs: 320,
    panelCrossfadeMs: 200,
    diffTokenPaddingPx: 2,
    diffTokenRadiusPx: 3,
    // Block-wide glass pass when switching lenses (single layer over code panel)
    glassBlockPassMs: 520,
  },
  layout: {
    tabMinHeightPx: 28,
    codeFontFamily: '"Space Mono", "SF Mono", "Fira Code", monospace',
    codeFontSizePx: 13,
    glassBlurPx: 12,
    defaultSlotHighlight: "plain",
  },
}
